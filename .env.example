# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://designer_user:CHANGE_ME_SECURE_PASSWORD@postgres:5432/authentik_login_designer

# Cache Configuration
# Local Docker: redis://valkey:6379/1
VALKEY_URL=redis://valkey:6379/1

# Security
# Generate with: openssl rand -hex 16
# CRITICAL: Change this immediately in production
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,https://identity.casmart.internal

# Public API Base URL
PUBLIC_API_BASE_URL=https://identity.casmart.internal

# Optional: Authentik Integration
# AUTHENTIK_URL=https://authentik.example.com
# AUTHENTIK_TOKEN=your_authentik_token
